{
  "appId": "com.whoisup.app",
  "appName": "App",
  "bundledWebRuntime": true,
  "npmClient": "yarn",
  "webDir": "www",
  "server": {
    "allowNavigation": [
      "amigosapp.nl",
      "*.amigosapp.nl",
      "app.amigosapp.nl",
      "com.whoisup.app"
    ]
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "ios": {
      "contentInset": "automatic"
  },
  "linuxAndroidStudioPath": "/snap/bin/android-studio"
}
