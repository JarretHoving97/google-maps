{
  "name": "capacitor-app",
  "version": "1.0.0",
  "description": "An Amazing Capacitor App",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build-ios": "npx cap sync ios",
    "build-android": "npx cap sync android",
    "build-all": "npx cap sync",
    "open-ios": "npx cap sync ios && npx cap open ios",
    "open-android": "npx cap sync android && npx cap open android",
    "copy-map-controller": "cp ./CustomMapViewController.swift ../cap-plugins/google-maps/ios/Sources/CapacitorGoogleMaps/CustomMapViewController.swift",
    "postinstall": "npm run copy-map-controller"
  },
  "keywords": [
    "capacitor",
    "mobile"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor-community/contacts": "7.0.0",
    "@capacitor-community/generic-oauth2": "github:JarretHoving97/generic-oauth2",
    "@capacitor-community/google-maps": "github:JarretHoving97/google-maps",
    "@capacitor-community/in-app-review": "7.1.0",
    "@capacitor-community/privacy-screen": "6.0.0",
    "@capacitor-community/safe-area": "7.0.0-beta.6",
    "@capacitor/android": "7.4.4",
    "@capacitor/app": "7.1.0",
    "@capacitor/camera": "7.0.2",
    "@capacitor/core": "7.4.4",
    "@capacitor/device": "7.0.2",
    "@capacitor/geolocation": "7.1.6",
    "@capacitor/ios": "7.4.4",
    "@capacitor/keyboard": "7.0.3",
    "@capacitor/preferences": "7.0.2",
    "@capacitor/push-notifications": "7.0.3",
    "@capacitor/share": "7.0.2",
    "@capacitor/splash-screen": "7.0.3",
    "@revenuecat/purchases-capacitor": "11.2.17",
    "capacitor-native-settings": "7.0.2",
    "capacitor-secure-storage-plugin": "0.12.0"
  },
  "devDependencies": {
    "@capacitor/cli": "7.4.4",
    "typescript": "^4.5.5"
  }
}
